<!DOCTYPE html>
<html lang="en">
  <head>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

  <body class="bg-gray-100 min-h-screen py-10">
    <div class="max-w-2xl mx-auto space-y-8">
      <!-- Create Task Card -->
      <div class="bg-white shadow-lg rounded-xl p-8">
        <h2 class="text-2xl font-bold text-center mb-6 text-gray-700">
          Create Task
        </h2>

        <form class="space-y-4" action="/create" method="post">
          <input
            type="text"
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400"
            placeholder="Enter title here..."
            name="title"
          />

          <textarea
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-400"
            rows="4"
            placeholder="Write your task here..."
            name="details"
          ></textarea>

          <input
            type="submit"
            value="Create Task"
            class="w-full bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600 transition duration-300 cursor-pointer"
          />
        </form>
      </div>

      <!-- Task Card -->
      <!-- Task List -->
<div class="space-y-4">

  <% if(files.length > 0){ %>

    <% files.forEach(function(val){ %>
      
      <div class="bg-white shadow-md rounded-xl p-6 hover:shadow-xl transition duration-300">
        
        <h1 class="text-lg font-semibold text-gray-800 mb-3">
          <%= val %>
        </h1>

        <a
          href="/file/<%=val%>"
          class="inline-block text-blue-500 font-medium hover:text-blue-600 hover:underline transition"
        >
          Read More →
        </a>
        <a
          href="/edit/<%=val%>"
          class="inline-block text-blue-500 font-medium hover:text-blue-600 hover:underline transition"
        >
          edit file 
        </a>


      </div>

    <% }) %>

  <% } else { %>

    <div class="bg-white shadow rounded-xl p-6 text-center text-gray-500">
      No tasks available
    </div>

  <% } %>

</div>
    </div>
  </body>
</html>
